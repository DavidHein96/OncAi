# Copy this file to .env and fill in your API keys.
# The .env file is loaded automatically and is git-ignored.

# Azure OpenAI (used by azure-responses backends)
AZURE_OPENAI_API_KEY=your-azure-api-key-here

# vLLM (uncomment if using a vLLM backend that requires auth)
# VLLM_API_KEY=your-vllm-api-key-here
